{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/human-data-budget/chain_result.schema.json",
  "title": "Human Data Budget chain result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "policy", "chain_seed", "budget_id", "generations_completed", "valid", "metrics", "consumed_human_tokens", "consumed_total_tokens", "exclusion_reason"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "policy": {"type": "string", "minLength": 1},
    "chain_seed": {"type": "integer"},
    "budget_id": {"type": "string", "minLength": 1},
    "generations_completed": {"type": "integer", "minimum": 1},
    "valid": {"type": "boolean"},
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["generation", "human_nll", "tail_retention"],
        "properties": {
          "generation": {"type": "integer", "minimum": 0},
          "human_nll": {"type": "number"},
          "tail_retention": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "consumed_human_tokens": {"type": "integer", "minimum": 0},
    "consumed_total_tokens": {"type": "integer", "minimum": 1},
    "exclusion_reason": {"type": ["string", "null"]}
  }
}
